# Intermediate

def find_range(*args):
    if not args:
        return None
    minimum_value = min(args)
    maximum_value = max(args)
    return (minimum_value, maximum_value)

print(f"Range of 3 numbers: {find_range(10, 2, 45)}")

test_scores = [78, 92, 85, 88, 91, 64, 99]
print(f"Range of test scores: {find_range(*test_scores)}")

# Advanced 

def calculate_statistics(*args):
    count = len(args)
    total_sum = sum(args)
    average = total_sum / count if count > 0 else 0
    return (count, total_sum, average)

def update_student_records(student_list, bonus):
    new_records = []
    for name, grade in student_list:
        new_records.append((name, grade + bonus))
    return new_records

# Demonstration
students = [("Alice", 85), ("Bob", 72), ("Charlie", 90)]
bonus_amount = 5

# 1. Update records
updated_students = update_student_records(students, bonus_amount)
print(f"Updated Records: {updated_students}")

# 2. Get stats for the new grades
new_grades = [record[1] for record in updated_students]
stats = calculate_statistics(*new_grades)

print(f"Stats (Count, Sum, Avg): {stats}")

