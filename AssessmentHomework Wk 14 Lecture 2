# Advanced

matrix = [[r * c for c in range(1, 5)] for r in range(1, 5)]

# Print in a formatted way
print("4x4 Multiplication Table:")
for row in matrix:
    print(row)

def sum_diagonal(matrix):
    return sum(matrix[i][i] for i in range(len(matrix)))

print(f"\nSum of diagonal: {sum_diagonal(matrix)}")

even_gen = (num for row in matrix for num in row if num % 2 == 0)

print("First 5 even numbers from table:")
for _ in range(5):
    print(next(even_gen), end=" ")

